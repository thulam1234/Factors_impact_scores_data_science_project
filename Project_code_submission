## cross validation
library(boot)
Model_10 <- glm(Exam_Score ~ Hours_Studied + Attendance + Parental_Involvement + 
                  Access_to_Resources + Extracurricular_Activities + Previous_Scores + 
                  Motivation_Level + Internet_Access + Tutoring_Sessions + 
                  Family_Income + Teacher_Quality + Peer_Influence + Physical_Activity + 
                  Learning_Disabilities + Parental_Education_Level + Distance_from_Home, data =           Student_performance)

cv.glm(data = Student_performance, glmfit = Model_10, K = 10)$delta[2]

Regression tree:

student <- read_excel(file.choose())
set.seed(90)
sample_index <- sample(nrow(student),nrow(student)*0.90)
student_train <- student[sample_index,]
student_test <- student[-sample_index,]
summary(student)
student_rpart <- rpart(formula = Exam_Score ~ ., data = student)
student_rpart
prp(student_rpart,digits = 4, extra = 1)
student_train_pred_tree = predict(student_rpart)
student_test_pred_tree = predict(student_rpart,student_test)
MSE.tree <- mean((student_test_pred_tree - student_test$Exam_Score)^2)
MSE.tree
student_tree_big1 <- rpart(formula = Exam_Score ~ ., data = student_train, cp = 0.003)
prp(student_tree_big1)
student_tree_big2 <- rpart(formula = Exam_Score ~ ., data = student_train, cp = 0.006)
prp(student_tree_big2)
student_train_pred_treebig = predict(student_tree_big2)
student_test_pred_treebig = predict(student_tree_big2,student_test)
MSE.treebig <- mean((student_test_pred_treebig - student_test$Exam_Score)^2)
MSE.treebig
student_reg = lm(Exam_Score~., data = student_train)
student_test_pred_reg = predict(student_reg, student_test)
mean((student_test_pred_reg - student_test$Exam_Score)^2)
student_glm = glm(Exam_Score ~ ., data = student)
cv.glm(data = student, glmfit = student_glm, K = 10)$delta[2]


